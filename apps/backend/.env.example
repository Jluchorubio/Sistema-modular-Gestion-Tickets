# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://tickets_user:tickets_pass@localhost:5432/tickets_db
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=tickets_db
DATABASE_USER=tickets_user
DATABASE_PASSWORD=tickets_pass

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# ─── Auth (Supabase) ──────────────────────────────────────────────────────────
# Supabase project URL: Settings → API → Project URL
SUPABASE_URL=
# Supabase anon/public key: Settings → API → anon public
SUPABASE_ANON_KEY=
# Supabase service_role key: Settings → API → service_role (keep secret!)
SUPABASE_SERVICE_ROLE_KEY=
# JWT secret: Settings → API → JWT Secret (mismo valor que usa Supabase internamente)
JWT_SECRET=
# URL pública del frontend (para OAuth redirect)
APP_URL=http://localhost:3000
# Google OAuth (configurar en Supabase Auth → Providers → Google)
# GOOGLE_CLIENT_ID y GOOGLE_CLIENT_SECRET van en Supabase dashboard, NO aquí

# ─── Notifications ────────────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@example.com

WHATSAPP_API_URL=
WHATSAPP_API_KEY=

# ─── Storage ──────────────────────────────────────────────────────────────────
STORAGE_DRIVER=local
STORAGE_PATH=./uploads
