# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://tickets_user:tickets_pass@localhost:5432/tickets_db
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=tickets_db
DATABASE_USER=tickets_user
DATABASE_PASSWORD=tickets_pass

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# ─── Auth (Supabase) ──────────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
JWT_SECRET=

# ─── Notifications ────────────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@example.com

WHATSAPP_API_URL=
WHATSAPP_API_KEY=

# ─── Storage ──────────────────────────────────────────────────────────────────
STORAGE_DRIVER=local
STORAGE_PATH=./uploads
