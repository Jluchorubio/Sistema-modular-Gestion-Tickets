# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
APP_NAME=NEXO ITSM
APP_URL=http://localhost:3000
BACKEND_URL=http://localhost:3001

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://tickets_user:tickets_pass@localhost:5432/tickets_db

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET=change-me-use-openssl-rand-base64-64

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins (no trailing slash)
ALLOWED_ORIGINS=http://localhost:3000

# ─── OAuth — Google (optional) ────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/api/v1/auth/google/callback

# ─── OAuth — Microsoft (optional) ─────────────────────────────────────────────
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_CALLBACK_URL=http://localhost:3001/api/v1/auth/microsoft/callback

# ─── Email — option A: SMTP (nodemailer) ─────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@example.com

# ─── Email — option B: Resend (fallback when SMTP_PASS absent) ───────────────
RESEND_API_KEY=

# ─── Notifications — WhatsApp (Meta Cloud API, optional) ─────────────────────
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=

# ─── Messaging — RabbitMQ (optional) ─────────────────────────────────────────
# Leave empty → in-process EventEmitter2 (dev default)
# Set → hybrid microservice mode with durable delivery
RABBITMQ_URL=

# ─── Storage ──────────────────────────────────────────────────────────────────
# STORAGE_DRIVER=local  → files saved to STORAGE_PATH (default, persisted via Docker volume)
# STORAGE_DRIVER=s3     → Cloudflare R2 or AWS S3 (required for multi-pod / prod)
STORAGE_DRIVER=local
STORAGE_PATH=./uploads

# R2 / S3 — required when STORAGE_DRIVER=s3
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=https://pub-xxxx.r2.dev

# ─── PostgreSQL (docker-compose only) ─────────────────────────────────────────
POSTGRES_DB=tickets_db
POSTGRES_USER=tickets_user
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_PORT=5432
