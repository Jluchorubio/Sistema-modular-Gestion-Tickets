{
  "name": "tickets-backend",
  "version": "0.1.0",
  "description": "Sistema modular de gestión de tickets - Backend",
  "private": true,
  "scripts": {
    "build": "nest build && tsc-alias",
    "start": "node dist/main",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "lint": "eslint \"{src,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:e2e": "jest --config ./test/jest-e2e.json"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1054.0",
    "@aws-sdk/lib-storage": "^3.1054.0",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^3.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/event-emitter": "^2.0.0",
    "@nestjs/jwt": "^10.0.0",
    "@nestjs/microservices": "^11.1.24",
    "@nestjs/passport": "^10.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/platform-socket.io": "^11.1.23",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^7.0.0",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^10.0.0",
    "@nestjs/websockets": "^11.1.23",
    "@socket.io/redis-adapter": "^8.3.0",
    "@types/passport-google-oauth20": "^2.0.17",
    "@types/speakeasy": "^2.0.10",
    "amqplib": "^2.0.1",
    "bcrypt": "^5.1.1",
    "class-transformer": "^0.5.0",
    "class-validator": "^0.14.0",
    "compression": "^1.8.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.0.0",
    "nodemailer": "^6.0.0",
    "passport": "^0.6.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.0",
    "pg": "^8.0.0",
    "qrcode": "^1.5.0",
    "reflect-metadata": "^0.1.14",
    "resend": "^6.12.2",
    "rxjs": "^7.0.0",
    "socket.io": "^4.8.3",
    "speakeasy": "^2.0.0",
    "typeorm": "^0.3.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "tsc-alias": "^1.8.10",
    "@types/amqplib": "^0.10.8",
    "@types/bcrypt": "^5.0.2",
    "@types/compression": "^1.8.1",
    "@types/jest": "^29.0.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.0.0",
    "@types/nodemailer": "^6.0.0",
    "@types/passport-jwt": "^4.0.0",
    "@types/passport-oauth2": "^1.8.0",
    "@types/qrcode": "^1.5.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "typescript": "^5.0.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^@gateway/(.*)$": "<rootDir>/gateway/$1",
      "^@modules/(.*)$": "<rootDir>/modules/$1",
      "^@shared/(.*)$": "<rootDir>/shared/$1",
      "^@infrastructure/(.*)$": "<rootDir>/infrastructure/$1"
    }
  }
}
