# ─── Public API URL (baked into browser JS at build time) ─────────────────────
# IMPORTANT: NEXT_PUBLIC_* vars are baked at BUILD TIME (next build), not runtime.
#
# Dev (without Docker):  http://localhost:3001
# Docker (nginx on :80): http://localhost   ← browser hits nginx, nginx routes /api to backend
# Production domain:     https://yourdomain.com
#
# This URL is what the browser uses directly (socket.io, any non-proxied calls).
# Set this as build arg in docker-compose — see `args.NEXT_PUBLIC_API_URL`.
NEXT_PUBLIC_API_URL=http://localhost:3001

# ─── Backend Internal URL (server-side rewrite proxy only) ────────────────────
# Used by Next.js next.config.mjs rewrites to proxy /api/* → backend.
# Never baked into browser JS. Must be reachable from the Next.js container.
#
# Docker: always http://backend:3001  (Docker internal network)
# Dev without Docker: http://localhost:3001
BACKEND_INTERNAL_URL=http://localhost:3001
