# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_DB=tickets_db
POSTGRES_USER=tickets_user
POSTGRES_PASSWORD=tickets_pass
POSTGRES_PORT=5432

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_PORT=6379

# ─── Ports ────────────────────────────────────────────────────────────────────
BACKEND_PORT=3001
FRONTEND_PORT=3000

# ─── Storage ──────────────────────────────────────────────────────────────────
# STORAGE_DRIVER=local       ← development default (ephemeral, NOT for production)
# STORAGE_DRIVER=s3          ← production (Cloudflare R2 or AWS S3)
STORAGE_DRIVER=local

# Cloudflare R2 (only when STORAGE_DRIVER=s3)
# Get these from Cloudflare Dashboard → R2 → Manage R2 API tokens
# R2_ACCOUNT_ID  = found in R2 overview page (Cloudflare Account ID)
# R2_ACCESS_KEY_ID / R2_SECRET_ACCESS_KEY = from API token
# R2_BUCKET_NAME = name of your R2 bucket
# R2_PUBLIC_URL  = public URL of the bucket (enable "Public access" on bucket settings)
#                  format: https://pub-xxxxxxxxxxxx.r2.dev
#                  or custom domain: https://assets.yourdomain.com
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=
