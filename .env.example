# ─── Base de datos ────────────────────────────────────────────────────────────
# DATABASE_URL en apps/backend/.env tiene prioridad absoluta (Railway por defecto).
# Las variables POSTGRES_* solo se usan cuando se levanta postgres local:
#   docker compose -f docker-compose.yml -f docker-compose.local.yml up -d
POSTGRES_DB=tickets_db
POSTGRES_USER=tickets_user
POSTGRES_PASSWORD=tickets_pass
POSTGRES_PORT=5432

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_PORT=6379

# ─── Ports ────────────────────────────────────────────────────────────────────
BACKEND_PORT=3001
FRONTEND_PORT=3000
HTTP_PORT=80
HTTPS_PORT=443

# ─── Frontend URLs ────────────────────────────────────────────────────────────
# Public URL baked into browser JS at build time (what the browser can reach)
# Docker + nginx: http://localhost  or  https://yourdomain.com
NEXT_PUBLIC_API_URL=http://localhost

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 64
JWT_SECRET=change-me-use-openssl-rand-base64-64

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for the backend
ALLOWED_ORIGINS=http://localhost,http://localhost:3000

# ─── App ──────────────────────────────────────────────────────────────────────
APP_URL=http://localhost
BACKEND_URL=http://localhost/api/v1
APP_NAME=NEXO ITSM

# ─── Google OAuth ──────────────────────────────────────────────────────────────
# console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client ID
# Authorized redirect URIs: https://yourdomain.com/api/v1/auth/google/callback
# Authorized JavaScript origins: https://yourdomain.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://yourdomain.com/api/v1/auth/google/callback

# ─── Email (pick one) ─────────────────────────────────────────────────────────
# Option A: SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@yourdomain.com
# Option B: Resend
RESEND_API_KEY=

# ─── Storage ──────────────────────────────────────────────────────────────────
# STORAGE_DRIVER=local   ← dev (ephemeral, NOT for production)
# STORAGE_DRIVER=s3      ← production (GCS, Cloudflare R2, AWS S3)
STORAGE_DRIVER=local

# ── Option A: Google Cloud Storage (GCS) ──────────────────────────────────────
# 1. GCP Console → Cloud Storage → Create bucket
# 2. Cloud Storage → Settings → Interoperability → Create HMAC key for service account
# 3. Grant bucket permission: allUsers → Storage Object Viewer (for public URLs)
# S3_ENDPOINT=https://storage.googleapis.com
# S3_REGION=us-central1              ← tu región del bucket
# R2_ACCESS_KEY_ID=HMAC_ACCESS_KEY   ← HMAC key from Interoperability
# R2_SECRET_ACCESS_KEY=HMAC_SECRET
# R2_BUCKET_NAME=nexo-itsm-uploads
# R2_PUBLIC_URL=https://storage.googleapis.com/nexo-itsm-uploads
S3_ENDPOINT=
S3_REGION=auto

# ── Option B: Cloudflare R2 ───────────────────────────────────────────────────
# 1. Cloudflare Dashboard → R2 → Create bucket
# 2. R2 → Manage R2 API Tokens → Create token (Object Read & Write)
# 3. Enable Public Access on bucket
# R2_ACCOUNT_ID = your Cloudflare Account ID (R2 overview page)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=
