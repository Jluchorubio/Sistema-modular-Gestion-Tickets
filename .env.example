# ─── Base de datos ────────────────────────────────────────────────────────────
# DATABASE_URL en apps/backend/.env tiene prioridad absoluta (Railway por defecto).
# Las variables POSTGRES_* solo se usan cuando se levanta postgres local:
#   docker compose -f docker-compose.yml -f docker-compose.local.yml up -d
POSTGRES_DB=tickets_db
POSTGRES_USER=tickets_user
POSTGRES_PASSWORD=tickets_pass
POSTGRES_PORT=5432

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_PORT=6379

# ─── Ports ────────────────────────────────────────────────────────────────────
BACKEND_PORT=3001
FRONTEND_PORT=3000
HTTP_PORT=80
HTTPS_PORT=443

# ─── Frontend URLs ────────────────────────────────────────────────────────────
# Public URL baked into browser JS at build time (what the browser can reach)
# Docker + nginx: http://localhost  or  https://yourdomain.com
NEXT_PUBLIC_API_URL=http://localhost

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 64
JWT_SECRET=change-me-use-openssl-rand-base64-64

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for the backend
ALLOWED_ORIGINS=http://localhost,http://localhost:3000

# ─── App ──────────────────────────────────────────────────────────────────────
APP_URL=http://localhost
BACKEND_URL=http://localhost/api/v1

# ─── Email (pick one) ─────────────────────────────────────────────────────────
# Option A: SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@yourdomain.com
# Option B: Resend
RESEND_API_KEY=

# ─── Storage ──────────────────────────────────────────────────────────────────
# STORAGE_DRIVER=local       ← development default (ephemeral, NOT for production)
# STORAGE_DRIVER=s3          ← production (Cloudflare R2 or AWS S3)
STORAGE_DRIVER=local

# Cloudflare R2 (only when STORAGE_DRIVER=s3)
# Get these from Cloudflare Dashboard → R2 → Manage R2 API tokens
# R2_ACCOUNT_ID  = found in R2 overview page (Cloudflare Account ID)
# R2_ACCESS_KEY_ID / R2_SECRET_ACCESS_KEY = from API token
# R2_BUCKET_NAME = name of your R2 bucket
# R2_PUBLIC_URL  = public URL of the bucket (enable "Public access" on bucket settings)
#                  format: https://pub-xxxxxxxxxxxx.r2.dev
#                  or custom domain: https://assets.yourdomain.com
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=
